{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Mint",
  "description": "End-user documentation for exploring, creating, and sharing with Mint.",
  "colors": {
    "primary": "#C4F042",
    "light": "#50600F",
    "dark": "#C4F042"
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "background": {
    "color": {
      "light": "#F2EDE8",
      "dark": "#1C1C1E"
    }
  },
  "fonts": {
    "heading": {
      "family": "Space Grotesk",
      "weight": 700
    },
    "body": {
      "family": "Space Grotesk",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "groups": [
      {
        "group": "User guide",
        "pages": [
          "index",
          "getting-started",
          "create-worlds-and-3d-models",
          "create-with-chat",
          "generation-settings",
          "mobile-capture",
          "my-models-and-viewer",
          "explore-share-and-go-live",
          "account-profile-and-billing",
          "plans-credits-and-billing",
          "faq-troubleshooting-and-limitations"
        ]
      },
      {
        "group": "Help and legal",
        "pages": [
          "support",
          "terms-of-service"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/mint-wordmark-light.svg",
    "dark": "/logo/mint-wordmark-dark.svg"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "assistant",
      "chatgpt",
      "claude",
      "perplexity",
      "grok",
      "aistudio",
      "devin",
      "windsurf",
      "mcp",
      "add-mcp",
      "cursor",
      "vscode",
      "devin-mcp"
    ],
    "display": "header"
  }
}
