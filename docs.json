{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Mint",
  "description": "End-user documentation for exploring, creating, and sharing with Mint.",
  "colors": {
    "primary": "#C4F58A",
    "light": "#D9FFAA",
    "dark": "#7C9F4A"
  },
  "appearance": {
    "default": "light"
  },
  "background": {
    "color": {
      "light": "#F4F3EE",
      "dark": "#0D0D0C"
    }
  },
  "fonts": {
    "heading": {
      "family": "Space Grotesk",
      "weight": 700
    },
    "body": {
      "family": "Space Grotesk",
      "weight": 400
    }
  },
  "favicon": {
    "light": "/logo/mint-icon-light.svg",
    "dark": "/logo/mint-icon-dark.svg"
  },
  "navigation": {
    "groups": [
      {
        "group": "User guide",
        "pages": [
          "index",
          "getting-started",
          "create-worlds-and-3d-models",
          "create-with-chat",
          "generation-settings",
          "mobile-capture",
          "my-models-and-viewer",
          "explore-share-and-go-live",
          "account-profile-and-billing",
          "plans-credits-and-billing",
          "faq-troubleshooting-and-limitations"
        ]
      },
      {
        "group": "Help and legal",
        "pages": [
          "support",
          "terms-of-service"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/mint-wordmark-light.svg",
    "dark": "/logo/mint-wordmark-dark.svg"
  },
  "contextual": {
    "options": [
      "copy",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
